# =============================================================================
# Environment variables — copy to .env (and .env.local) and fill in real values.
# .env* is gitignored. NEVER commit real secrets. NEVER prefix secrets with
# NEXT_PUBLIC_ (that exposes them to the browser bundle).
# =============================================================================

# --- Supabase Postgres (used by Prisma) -------------------------------------
# Pooled connection (Supavisor, port 6543) — used by the app at runtime on Vercel.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used ONLY by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (admin dashboard login) ----------------------------------
# From Supabase: Project Settings → Data API / API Keys. The anon key is safe in the browser.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon public key>"
# Comma-separated emails allowed into /admin (your Supabase Auth user's email).
ADMIN_EMAILS="owner@example.com"
# Optional: exact admin hostname in production. If unset, any "admin." subdomain
# is treated as the admin host. e.g. ADMIN_HOST="admin.binukbok.com"
# ADMIN_HOST="admin.yourdomain.com"

# --- Resend (confirmation emails) — Phase 1 ---------------------------------
# RESEND_API_KEY=

# --- OpenAI (admin chatbot) — Phase 3, server-side only ---------------------
# OPENAI_API_KEY=

# --- Site URL (used to build the public booking-view link in calendar events) -
# Local dev defaults to http://localhost:3000 if unset. Set to the real domain in prod.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
